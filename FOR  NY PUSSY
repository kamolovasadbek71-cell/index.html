<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>i love you pussu</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&display=swap');

        body {
            margin: 0;
            padding: 0;
            background-color: #0a0505; /* Тёмный фон, как на скрине */
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
            font-family: 'Space Grotesk', sans-serif;
        }

        .container {
            position: relative;
            /* Отдалили: контейнер стал меньше (60vmin вместо 90vmin) */
            width: 60vmin;
            height: 60vmin;
        }

        .tag {
            position: absolute;
            color: #ff003c; /* Тот самый красный неон */
            text-shadow: 0 0 5px rgba(255, 0, 60, 0.9), 0 0 10px rgba(255, 0, 60, 0.5);
            white-space: nowrap;
            font-weight: bold;
            opacity: 0;
            transform: translate(-50%, -50%);
            /* Бесконечный цикл появления и исчезновения */
            animation: randomBlink 3s ease-in-out infinite;
        }

        /* Анимация непредсказуемого мерцания: плавно горит -> затухает -> горит снова */
        @keyframes randomBlink {
            0%, 100% { 
                opacity: 0; 
                transform: translate(-50%, -50%) scale(0.9) blur(1px);
                text-shadow: 0 0 5px rgba(255, 0, 60, 0.6);
            }
            45%, 55% { 
                opacity: 0.8; 
                transform: translate(-50%, -50%) scale(1) blur(0px);
                text-shadow: 0 0 10px rgba(255, 0, 60, 1), 0 0 20px rgba(255, 0, 60, 0.7);
            }
        }

        .scanline {
            width: 100%;
            height: 100px;
            z-index: 20;
            background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(255, 0, 60, 0.05) 50%, rgba(0, 0, 0, 0) 100%);
            opacity: 0.8;
            position: absolute;
            animation: scanline 6s linear infinite;
            pointer-events: none;
        }

        @keyframes scanline {
            0% { top: -100px; }
            100% { top: 100vh; }
        }
    </style>
</head>
<body>

    <div class="scanline"></div>
    <div class="container" id="container"></div>

    <script>
        const container = document.getElementById('container');
        
        // Математическая функция для генерации точек строго по контуру сердца
        function getHeartPoint(t, scale) {
            const x = 16 * Math.pow(Math.sin(t), 3);
            const y = 13 * Math.cos(t) - 5 * Math.cos(2*t) - 2 * Math.cos(3*t) - Math.cos(4*t);
            // Возвращаем координаты, центрированные в контейнере
            return {
                x: (x * scale) + container.offsetWidth / 2,
                y: (-y * scale) + container.offsetHeight / 2
            };
        }

        // Количество надписей для четкого контура
        const totalTags = 150; 
        // Множитель размера сердца (сделали меньше, чтобы отдать)
        const heartSizeMultiplier = 8; 

        for (let i = 0; i < totalTags; i++) {
            // Равномерно распределяем точки по математическому контуру сердца
            const t = (i / totalTags) * Math.PI * 2;
            const point = getHeartPoint(t, heartSizeMultiplier);

            const tag = document.createElement('div');
            tag.classList.add('tag');
            tag.innerText = 'i love you';
            
            // Четкая посадка на свои места
            tag.style.left = point.x + 'px';
            tag.style.top = point.y + 'px';

            // Настраиваем размер: все фразы одинаково мелкие, как на скрине
            tag.style.fontSize = '2.2vmin';

            // Жесткий разброс по времени, чтобы они мерцали ХАОТИЧНО, а не по очереди
            tag.style.animationDelay = `${Math.random() * 5}s`;

            container.appendChild(tag);
        }
    </script>
</body>
</html>  
